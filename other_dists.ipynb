   "source": [
    "$$\n",
    "\\hat \\lambda _{MLE} = \\bar x = \\frac{\\sum x_i}{n}\n",
    "$$\n",
    "\n",
    "$$\n",
    "\\mathbb E[\\bar x] = \\frac{1}{n} \\sum \\mathbb E[x_i] = \\frac{n\\lambda}{n} = \\lambda\n",
    "$$\n",
    "\n",
    "$$\n",
    "\\mathrm{Var}[\\bar x] = \\frac{1}{n^2} \\sum \\mathrm{Var}(x_i) = \\frac{n \\lambda}{n^2} = \\frac{\\lambda}{n}\n",
    "$$\n",
    "\n"
   ]
  }
